{
  "name": "mobility-platform",
  "version": "0.1.0",
  "private": true,
  "description": "End-to-end DevOps/SRE starter platform for payment, consumer, driver, and booking microservices.",
  "workspaces": [
    "services/*"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:app": "npm run test:app --workspaces --if-present",
    "start:booking": "npm --workspace services/booking-service start",
    "start:payment": "npm --workspace services/payment start",
    "start:consumer": "npm --workspace services/consumer-app start",
    "start:driver": "npm --workspace services/driver-app start"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "supertest": "^7.1.1"
  }
}
